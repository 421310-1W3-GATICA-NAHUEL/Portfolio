# Variables de entorno — Portfolio Backend
# Copiá este archivo como .env y completá los valores

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Obtené tu connection string desde: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@cluster0.xxxxx.mongodb.net/portfolio

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Cualquier string largo y aleatorio sirve (ej: openssl rand -base64 32)
JWT_SECRET=tu_secreto_super_seguro_aqui

# ─── Resend (envío de emails) ─────────────────────────────────────────────────
# Creá una cuenta gratuita en https://resend.com y generá una API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email al que llegan los mensajes del formulario de contacto
CONTACT_EMAIL=gaticanahuel70@gmail.com

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Creá una base gratis en https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu_token_de_upstash

# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
